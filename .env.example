# Variáveis de Configuração - SR Decorações

## 📋 Informações da Empresa

# URL do site (altere para seu domínio)
NEXT_PUBLIC_SITE_URL=https://sr-decoracoes.com.br

# Informações de Contato
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999
NEXT_PUBLIC_PHONE_DISPLAY=+55 (11) 99999-9999
NEXT_PUBLIC_EMAIL=contato@sr-decoracoes.com.br

# Endereço
NEXT_PUBLIC_STREET_ADDRESS=Sua Rua e Número
NEXT_PUBLIC_ADDRESS_LOCALITY=São Paulo
NEXT_PUBLIC_ADDRESS_REGION=SP
NEXT_PUBLIC_POSTAL_CODE=00000-000
NEXT_PUBLIC_ADDRESS_COUNTRY=BR

# Redes Sociais
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/srdecoracoes
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/srdecoracoes
NEXT_PUBLIC_GOOGLE_BUSINESS_URL=https://www.google.com/maps/place/SR+Decoracoes
NEXT_PUBLIC_GOOGLE_MAPS_EMBED=seu-iframe-google-maps-aqui

# Google Search Console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=seu-google-site-verification-aqui

# Google Analytics (opcional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=seu-ga-id-aqui

# Configurações de Rating
NEXT_PUBLIC_RATING_VALUE=4.8
NEXT_PUBLIC_RATING_COUNT=150

## 📝 Notas de Uso

# 1. Substitua todos os valores acima com dados reais
# 2. Se estiver usando Next.js, use process.env.NEXT_PUBLIC_* para acessar
# 3. Não cometa dados sensíveis (senhas, chaves privadas)
# 4. Use NEXT_PUBLIC_ apenas para valores que podem ser expostos no cliente
